<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="?attr/android:windowBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Mode Selector -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tracking Mode"
            android:textSize="16sp"
            android:textStyle="bold"/>

        <RadioGroup
            android:id="@+id/rg_mode_selector"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <RadioButton
                android:id="@+id/rb_automatic"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Automatic"
                android:checked="true"/>

            <RadioButton
                android:id="@+id/rb_semi_auto"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Semi-Auto"/>

            <RadioButton
                android:id="@+id/rb_manual"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Manual"/>
        </RadioGroup>

        <!-- Status Card -->
        <TextView
            android:id="@+id/tv_motor_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Motor Status: Ready"
            android:textSize="18sp"
            android:textStyle="bold"
            android:padding="12dp"
            android:background="@drawable/rounded_background"
            android:gravity="center"
            android:layout_marginTop="16dp"/>

        <!-- Tilt Angle Display -->
        <TextView
            android:id="@+id/tv_tilt_angle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tilt Angle: 0.0°"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:padding="16dp"
            android:background="@drawable/rounded_background"
            android:gravity="center"/>

        <!-- Weather Status Display -->
        <TextView
            android:id="@+id/tv_weather_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Weather: Unknown"
            android:textSize="14sp"
            android:layout_marginTop="8dp"
            android:padding="8dp"
            android:background="@drawable/rounded_background"
            android:gravity="center"/>

        <!-- Semi-Auto Confirmation Banner (hidden by default) -->
        <LinearLayout
            android:id="@+id/layout_semi_auto_confirm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="12dp"
            android:padding="12dp"
            android:background="@drawable/rounded_background"
            android:visibility="gone">

            <TextView
                android:id="@+id/tv_confirm_message"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⚠ Weather change detected. Approve panel repositioning?"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="center"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:gravity="center">

                <Button
                    android:id="@+id/btn_confirm_approve"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="✓ Approve"
                    android:layout_marginEnd="4dp"/>

                <Button
                    android:id="@+id/btn_confirm_reject"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="✗ Reject"
                    android:layout_marginStart="4dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Weather Preset Buttons (Semi-Auto + Manual) -->
        <LinearLayout
            android:id="@+id/layout_weather_presets"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Weather Presets"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <Button
                    android:id="@+id/btn_weather_overcast"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="☁ Overcast\n90°"
                    android:layout_marginEnd="4dp"/>

                <Button
                    android:id="@+id/btn_weather_rain"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🌧 Rain\n60°"
                    android:layout_marginEnd="4dp"/>

                <Button
                    android:id="@+id/btn_weather_snow"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="❄ Snow\n15°"
                    android:layout_marginEnd="4dp"/>

                <Button
                    android:id="@+id/btn_weather_clear"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="☀ Clear\nSun"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Manual Controls Section (Manual Mode Only) -->
        <LinearLayout
            android:id="@+id/layout_manual_controls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Arc Angle Slider -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Panel Tilt Control"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp"/>

            <com.example.coen490solarpanel.ArcSliderView
                android:id="@+id/arc_slider"
                android:layout_width="match_parent"
                android:layout_height="280dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"/>

            <!-- Hold-to-Operate Tilt Buttons -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Fine Tilt Control"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⚠ Hold button to operate"
                android:textSize="12sp"
                android:layout_marginTop="4dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <Button
                    android:id="@+id/btn_tilt_up"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="↑ Up"
                    android:layout_marginEnd="8dp"/>

                <Button
                    android:id="@+id/btn_tilt_down"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="↓ Down"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Emergency Stop (Always Visible) -->
        <Button
            android:id="@+id/btn_stop_all"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⛔ EMERGENCY STOP"
            android:backgroundTint="@android:color/holo_red_dark"
            android:textColor="@android:color/white"
            android:layout_marginTop="32dp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Long-press for emergency stop dialog"
            android:textSize="10sp"
            android:gravity="center"
            android:layout_marginTop="4dp"/>

    </LinearLayout>
</ScrollView>
