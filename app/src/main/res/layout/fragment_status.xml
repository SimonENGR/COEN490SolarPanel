<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Status Display -->
        <TextView
            android:id="@+id/tv_battery_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Battery: -- / -- kWh (--%)"/>

        <TextView
            android:id="@+id/tv_battery_sensor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Battery Sensor: --"
            android:layout_marginTop="8dp"/>

        <TextView
            android:id="@+id/tv_panel_sensor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Panel Sensor: --"
            android:layout_marginTop="8dp"/>

        <TextView
            android:id="@+id/tv_current_energy"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Current Harvest: --"
            android:layout_marginTop="8dp"/>

        <TextView
            android:id="@+id/tv_mean_energy"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="7-Day Average: --"
            android:layout_marginTop="8dp"/>

        <!-- Motor Status Indicator -->
        <TextView
            android:id="@+id/tv_motor_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Motor Status: Ready"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp"
            android:padding="12dp"
            android:background="@drawable/rounded_background"
            android:gravity="center"/>

        <!-- Cleaning Motor Controls -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cleaning Brush"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚠ Hold button to operate"
            android:textSize="12sp"
            android:layout_marginTop="4dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <Button
                android:id="@+id/btn_clean_up"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="↑ Forward"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btn_clean_down"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="↓ Reverse"/>
        </LinearLayout>

        <!-- Tilt Motor Controls -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Panel Tilt"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚠ Hold button to operate"
            android:textSize="12sp"
            android:layout_marginTop="4dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <Button
                android:id="@+id/btn_tilt_up"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="↑ Up"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btn_tilt_down"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="↓ Down"/>
        </LinearLayout>

        <!-- Emergency Stop -->
        <Button
            android:id="@+id/btn_stop_all"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⛔ STOP ALL MOTORS"
            android:backgroundTint="@android:color/holo_red_dark"
            android:textColor="@android:color/white"
            android:layout_marginTop="24dp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Long-press for emergency stop dialog"
            android:textSize="10sp"
            android:gravity="center"
            android:layout_marginTop="4dp"/>

    </LinearLayout>
</ScrollView>