<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="?attr/android:windowBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ============================================================ -->
        <!-- TILT ANGLE DISPLAY                                           -->
        <!-- ============================================================ -->
        <TextView
            android:id="@+id/tv_tilt_angle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tilt Angle: 0.00°"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:padding="16dp"
            android:background="@drawable/rounded_background"
            android:gravity="center"/>

        <!-- ============================================================ -->
        <!-- PRECISION TILT CONTROL                                       -->
        <!-- ============================================================ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Precision Tilt Control"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <Button
                android:id="@+id/btn_minus_1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="−1.0°"
                android:layout_marginEnd="4dp"/>

            <Button
                android:id="@+id/btn_minus_01"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="−0.1°"
                android:layout_marginEnd="4dp"/>

            <Button
                android:id="@+id/btn_plus_01"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="+0.1°"
                android:layout_marginEnd="4dp"/>

            <Button
                android:id="@+id/btn_plus_1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="+1.0°"/>
        </LinearLayout>

        <!-- Target Angle + GO -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical">

            <EditText
                android:id="@+id/et_target_angle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Target angle (°)"
                android:inputType="numberDecimal|numberSigned"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btn_go_angle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GO"/>
        </LinearLayout>

        <!-- Motor Status Indicator -->
        <TextView
            android:id="@+id/tv_motor_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Motor Status: Ready"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="12dp"
            android:padding="12dp"
            android:background="@drawable/rounded_background"
            android:gravity="center"/>

        <!-- ============================================================ -->
        <!-- WIPER POSITION DISPLAY                                       -->
        <!-- ============================================================ -->
        <TextView
            android:id="@+id/tv_wiper_position"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Wiper position bottom to top (0-100%): --.- %"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp"
            android:padding="16dp"
            android:background="@drawable/rounded_background"
            android:gravity="center"/>

        <!-- Full Clean Cycle Button -->
        <Button
            android:id="@+id/btn_full_clean"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="START CLEANING CYCLE"
            android:textStyle="bold"
            android:layout_marginTop="12dp"/>

        <!-- ============================================================ -->
        <!-- CLEANING BRUSH HOLD-TO-OPERATE                               -->
        <!-- ============================================================ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cleaning Brush"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚠ Hold button to operate"
            android:textSize="12sp"
            android:layout_marginTop="4dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <Button
                android:id="@+id/btn_clean_up"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="↑ Forward"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btn_clean_down"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="↓ Reverse"/>
        </LinearLayout>

        <!-- ============================================================ -->
        <!-- PANEL TILT HOLD-TO-OPERATE                                   -->
        <!-- ============================================================ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Panel Tilt"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚠ Hold button to operate"
            android:textSize="12sp"
            android:layout_marginTop="4dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <Button
                android:id="@+id/btn_tilt_up"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="↑ Up"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btn_tilt_down"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="↓ Down"/>
        </LinearLayout>

        <!-- ============================================================ -->
        <!-- EMERGENCY STOP                                               -->
        <!-- ============================================================ -->
        <Button
            android:id="@+id/btn_stop_all"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="STOP ALL MOTORS"
            android:backgroundTint="@android:color/holo_red_dark"
            android:textColor="@android:color/white"
            android:layout_marginTop="24dp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Long-press for emergency stop dialog"
            android:textSize="10sp"
            android:gravity="center"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="16dp"/>

    </LinearLayout>
</ScrollView>